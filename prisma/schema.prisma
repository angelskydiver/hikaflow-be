model Collaborator {
  id                String  @id @default(uuid())
  name              String
  email             String?
  githubUsername    String?
  bitbucketUsername String?
  totalPrCount      Int     @default(0) // Total number of closed PRs

  // Code Efficiency Metrics
  performanceGains       Float @default(0)
  codeFootprintReduction Float @default(0)
  refactorQuality        Float @default(0)
  cleanDiffRatio         Float @default(0)

  // Business Impact Metrics
  criticalModuleImpact Float @default(0)
  speedToDeploy        Float @default(0)
  errorRateReduction   Float @default(0)
  firstTimeRight       Float @default(0)

  // Collaboration Metrics
  ownershipClarity      Float @default(0)
  internalDocumentation Float @default(0)

  // Relationships
  organizations Organization[] // Many-to-many with organizations
  repositories  Repository[] // Many-to-many with repositories

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
