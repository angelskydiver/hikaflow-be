// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserLoginType {
  CUSTOM @map("1")
  GOOGLE @map("2")
}

enum RepositoryProvider {
  GITHUB    @map("1")
  BITBUCKET @map("2")
}

enum AccountCredentialsType {
  GITHUB_TOKEN    @map("1")
  BITBUCKET_TOKEN @map("2")
}

enum CommentStatus {
  NOT_TRACKED @map("1")
  OPEN        @map("2")
  OUTDATED    @map("3")
}

enum PrTrackerStatus {
  PENDING  @map("1")
  APPROVED @map("2")
  REJECTED @map("3")
}

enum CommentType {
  NOT_TRACKED  @map("-")
  ISSUE        @map("1")
  PULL_REQUEST @map("2")
}

enum OrganizationalAccountRole {
  MEMBER  @map("MEMBER")
  MANAGER @map("MANAGER")
  ADMIN   @map("ADMIN")
}

enum DuplicateCode {
  DUPLICATE      @map("DUPLICATE")
  IDENTICAL_CODE @map("IDENTICAL_CODE")
}

enum FileType {
  PROJECT_SETUP
  CONTROLLER
  SERVICE
  SCHEMA
  MIGRATION
  REPOSITORY
  CONFIG
  CONSTANTS
  MIDDLEWARE
  UTILITY
  JOB
  MODULE
  ASSETS
  DOCUMENTATION
  TEST
  EVENT_HANDLER
  LOGGING
}

enum ScanStatus {
  PENDING     @map("PENDING")
  IN_PROGRESS @map("IN_PROGRESS")
  COMPLETED   @map("COMPLETED")
  FAILED      @map("FAILED")
}

enum SubscriptionPlanType {
  TRIAL    @map("TRIAL") // Free trial: 2 repos max, 5 questions daily, expires in 15 days
  BASIC    @map("BASIC") // $20/project + 50 cents per evaluation
  STANDARD @map("STANDARD") // $30/project + 25 cents per evaluation
  PREMIUM  @map("PREMIUM") // $50/project + 10 cents per evaluation
  CUSTOM   @map("CUSTOM") // Custom pricing
}

enum InvoiceStatus {
  DRAFT    @map("DRAFT")
  PENDING  @map("PENDING")
  PAID     @map("PAID")
  FAILED   @map("FAILED")
  CANCELED @map("CANCELED")
}

model User {
  id        String        @id @default(uuid())
  firstName String
  lastName  String
  email     String        @unique
  password  String
  verified  Boolean       @default(false)
  sendEmail Boolean       @default(true)
  loginType UserLoginType @default(CUSTOM)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  account                Account?
  // accountId String? // Foreign key for the Account relation
  OrganizationInvitation OrganizationInvitation[]
}

model Account {
  id                  String                 @id @default(uuid())
  status              String                 @default("active")
  subscribedPlanType  Int                    @default(1)
  tokens              Int                    @default(0)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  userId              String                 @unique
  user                User                   @relation(fields: [userId], references: [id])
  verified            Boolean                @default(false)
  repositories        AccountRepository[] // Many-to-many relationship
  accountCredentials  AccountCredentials[]
  accountOrganization OrganizationAccounts[]
  scan                RepositoryScan[]
  AssistedQuestions   AssistedQuestions[]
  // Researcher          Researcher[]
  // ResearchAssistant   ResearchAssistant[]
}

model Organization {
  id                     String  @id @default(uuid())
  name                   String  @unique
  logo                   String? @default("")
  defaultPaymentMethodId String? @default("")

  organizationalAccount  OrganizationAccounts[] // Many-to-many relationship
  repositories           Repository[] // One-to-many relation with repositories
  AccountRepository      AccountRepository[] // Many-to-many relationship
  OrganizationInvitation OrganizationInvitation[]
  subscriptions          Subscription[]
  usageLogs              UsageLog[]
  // Researcher             Researcher[]
  // ResearchAssistant      ResearchAssistant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrganizationAccounts {
  id             String       @id @default(uuid())
  accountId      String
  organizationId String
  role           String       @default("MEMBER")
  organization   Organization @relation(fields: [organizationId], references: [id])
  account        Account      @relation(fields: [accountId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AccountCredentials {
  id              String                 @id @default(uuid())
  type            AccountCredentialsType @default(GITHUB_TOKEN)
  value           String
  bitbucketSecret Json?                  @default("{}")

  accountId String
  account   Account @relation(fields: [accountId], references: [id])
}

model bitbucketSecret {
  id        String   @id @default(uuid())
  clientKey String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationCode {
  id        String   @id @default(uuid())
  code      String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accountId String
  // account   Account @relation(fields: [accountId], references: [id])
}

// repositories

// repository can only be ad by admin
model Repository {
  id             String             @id @default(uuid())
  repositoryId   String             @unique // GitHub repository reference
  provider       RepositoryProvider @default(GITHUB)
  name           String
  owner          String             @default("mudassir693")
  baseBranch     String             @default("main")
  private        Boolean            @default(false)
  description    String             @default("")
  language       String             @default("")
  organizationId String? // Foreign key for the organization (optional)
  organization   Organization?      @relation(fields: [organizationId], references: [id]) // Optional relation

  accounts     AccountRepository[] // Many-to-many relationship
  comments     Comment[]
  reports      ExecutiveReport[]
  codeOverview CodeOverview[]

  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  repositorySettings RepositorySettings[]
  commitSummary      commitSummary[]
  duplicatedCode     DuplicatedCode[]
  file               FileDocumentation[]
  scan               RepositoryScan[]
  AssistedQuestions  AssistedQuestions[]
  UsageLog           UsageLog[]
  // Researcher         Researcher[]
}

model AccountRepository {
  accountId      String
  repositoryId   String
  organizationId String? // Foreign key for the organization (optional)
  organization   Organization? @relation(fields: [organizationId], references: [id]) // Optional relation

  account     Account          @relation(fields: [accountId], references: [id])
  repository  Repository       @relation(fields: [repositoryId], references: [id])
  evaluations RepoEvaluation[]

  @@id([accountId, repositoryId]) // Composite primary key
}

model RepoEvaluation {
  id                  String   @id @default(uuid())
  accountId           String
  repositoryId        String
  accountRepositoryId String
  score               Int
  response            Json     @default("{}")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  accountRepository AccountRepository @relation(fields: [accountId, repositoryId], references: [accountId, repositoryId])
}

model PullRequest {
  id            String @id @default(uuid())
  repositoryId  String
  prUrl         String
  prNumber      Int
  prTitle       String
  prDescription String @default("")
  head          String
  base          String
  summary       String @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // repository Repository @relation(fields: [repositoryId], references: [repositoryId])
  // comments Comment[]
}

model Comment {
  id            String        @id @default(uuid())
  repositoryId  String
  prId          String?       @default("")
  content       String
  line          Int
  file          String
  issue         String
  type          CommentType   @default(NOT_TRACKED)
  issueCategory String        @default("CodeSmells")
  status        CommentStatus @default(NOT_TRACKED)
  severity      String        @default("LOW")
  reason        String        @default("")

  repository Repository @relation(fields: [repositoryId], references: [repositoryId])
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model ExecutiveReport {
  id           String @id @default(uuid())
  repositoryId String
  prNumber     Int
  summary      Json   @default("{}")

  repository    Repository      @relation(fields: [repositoryId], references: [repositoryId])
  codeOverview  CodeOverview[]
  commitSummary commitSummary[]
}

model CodeOverview {
  id      String @id @default(uuid())
  summary Json   @default("{}")

  reportId     String          @default("2a26d830-794d-452c-9d23-3d20902bce2b")
  repositoryId String
  repository   Repository      @relation(fields: [repositoryId], references: [repositoryId])
  report       ExecutiveReport @relation(fields: [reportId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PrTracker {
  id        String          @id @default(uuid())
  prId      String
  status    PrTrackerStatus @default(PENDING)
  try       Int             @default(1)
  response  Json            @default("{}")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model commitSummary {
  id            String @id @default(uuid())
  repositoryId  String
  reportId      String
  commitId      String
  commitMessage String
  additions     Int
  deletions     Int
  totalFiles    Int
  committer     String
  summary       Json   @default("{}")

  repository Repository      @relation(fields: [repositoryId], references: [repositoryId])
  report     ExecutiveReport @relation(fields: [reportId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RepositorySettings {
  id           String  @id @default(uuid())
  repositoryId String
  key          String
  description  String
  prompt       String
  active       Boolean
  category     String

  repository Repository @relation(fields: [repositoryId], references: [repositoryId])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrganizationInvitation {
  id             String                    @id @default(uuid())
  organizationId String
  name           String
  email          String
  role           OrganizationalAccountRole @default(MEMBER)
  status         String                    @default("pending")
  inviterId      String                    @default("5058706f-b560-41bf-8bff-483514d3e9e8")
  inviter        User                      @relation(fields: [inviterId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
}

model DuplicatedCode {
  id           String        @id @default(uuid())
  repositoryId String
  file         String
  content      String
  line         Int
  duplicateOf  Json          @default("{}")
  prId         String
  type         DuplicateCode @default(DUPLICATE)
  repository   Repository    @relation(fields: [repositoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()
}

model FileDocumentation {
  id               String                      @id @default(uuid())
  name             String // File name
  fullPath         String // Full file path
  imports          String[] // List of imported files
  exports          String[] // List of exported files
  functions        Json // Hierarchical function structure
  classes          Json // Hierarchical class structure
  components       Json                        @default("[]") // Hierarchical function structure
  fileType         String[] // Enum-based file classification
  summary          String // AI-generated file summary
  repositoryId     String // Link to the repository
  repositoryScanId String // Link to the repository scan
  summaryEmbedding Unsupported("vector(768)")?
  repositoryScan   RepositoryScan              @relation(fields: [repositoryScanId], references: [id], onDelete: Cascade)
  repository       Repository                  @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
}

model RepositoryScan {
  id                String     @id @default(uuid())
  repositoryId      String // Links to the Repository being scanned
  accountId         String // Links to the Account that initiated the scan
  status            ScanStatus @default(PENDING) // Status of the scan (Pending, In Progress, Completed, Failed)
  tokenUsed         Int        @default(0) // Tokens utilized in this scan
  totalFiles        Int        @default(0) // Total number of files need to be analyzed
  totalFilesScanned Int        @default(0) // Total number of files analyzed
  startedAt         DateTime? // When the scan started
  completedAt       DateTime? // When the scan finished
  logs              String? // Any error or process logs

  account    Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  fileDocumentation FileDocumentation[]
  AssistedQuestions AssistedQuestions[]
}

model AssistedQuestions {
  id             String  @id @default(uuid())
  question       String
  answer         Json    @default("{}")
  repositoryId   String
  scanId         String
  tokenUtilized  Int     @default(0)
  saved          Boolean @default(false)
  accountId      String
  organizationId String?

  account    Account        @relation(fields: [accountId], references: [id])
  repository Repository     @relation(fields: [repositoryId], references: [id])
  scan       RepositoryScan @relation(fields: [scanId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PricingPlan {
  id              String               @id @default(uuid())
  name            String
  planType        SubscriptionPlanType
  basePrice       Float // Base price per project
  evaluationPrice Float // Price per evaluation
  active          Boolean              @default(true)
  stripeProductId String? // Stripe product ID
  stripePriceId   String? // Stripe price ID
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id                   String       @id @default(uuid())
  organizationId       String
  organization         Organization @relation(fields: [organizationId], references: [id])
  pricingPlanId        String
  pricingPlan          PricingPlan  @relation(fields: [pricingPlanId], references: [id])
  stripeCustomerId     String? // Keep as is, don't change to a relation yet
  stripeSubscriptionId String? // Stripe subscription ID
  startDate            DateTime     @default(now())
  endDate              DateTime?
  isActive             Boolean      @default(true)
  customBasePrice      Float? // Only for custom plans
  customEvalPrice      Float? // Only for custom plans
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  invoices  Invoice[]
  usageLogs UsageLog[]
}

model Invoice {
  id                    String        @id @default(uuid())
  subscriptionId        String
  subscription          Subscription  @relation(fields: [subscriptionId], references: [id])
  invoiceNumber         String        @unique
  amount                Float
  tax                   Float         @default(0)
  total                 Float
  status                InvoiceStatus @default(DRAFT)
  dueDate               DateTime
  paidDate              DateTime?
  stripeInvoiceId       String? // Stripe invoice ID
  stripePaymentIntentId String? // Stripe payment intent ID
  description           String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  invoiceItems InvoiceItem[]
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id])
  description String
  quantity    Int
  unitPrice   Float
  amount      Float
  type        String // PROJECT or EVALUATION
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UsageLog {
  id             String       @id @default(uuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  repositoryId   String?
  repository     Repository?  @relation(fields: [repositoryId], references: [id])
  type           String // PR_ANALYSIS, ASSISTANT_QUESTION, etc.
  description    String
  counted        Boolean      @default(false) // Whether it's been counted in an invoice
  invoiceId      String? // The invoice it was counted in
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

