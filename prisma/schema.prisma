model RepositoryScan {
  id                String     @id @default(uuid())
  repositoryId      String // Links to the Repository being scanned
  accountId         String // Links to the Account that initiated the scan
  status            ScanStatus @default(PENDING) // Status of the scan (Pending, In Progress, Completed, Failed)
  tokenUsed         Int        @default(0) // Tokens utilized in this scan
  totalFiles        Int        @default(0) // Total number of files need to be analyzed
  totalFilesScanned Int        @default(0) // Total number of files analyzed
  startedAt         DateTime? // When the scan started
  completedAt       DateTime? // When the scan finished
  logs              String? // Any error or process logs

  account    Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  fileDocumentation FileDocumentation[]
  AssistedQuestions AssistedQuestions[]
}

model Thread {
  id           String              @id @default(uuid())
  title        String              @default("")
  repositoryId String
  repository   Repository          @relation(fields: [repositoryId], references: [id])
  questions    AssistedQuestions[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model AssistedQuestions {
  id            String   @id @default(uuid())
  question      String
  answer        Json     @default("{}")
  summary       String   @default("")
  accountId     String?
  repositoryId  String
  scanId        String
  tokenUtilized Int      @default(0)
  saved         Boolean  @default(false)
  threadId      String?
  thread        Thread?  @relation(fields: [threadId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // account          Account         @relation(fields: [accountId], references: [id])
  repository       Repository      @relation(fields: [repositoryId], references: [id])
  // scan       RepositoryScan @relation(fields: [scanId], references: [id])
  RepositoryScan   RepositoryScan? @relation(fields: [repositoryScanId], references: [id])
  repositoryScanId String?
}

model RegressionReport {
  id                 String   @id @default(uuid())
  repositoryId       String
  prNumber           Int
  status             String
  summary            String
  impactedFlows      Json
  changedBehavior    Json
  potentialBreakages Json
  testCases          Json
  organizationId     String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  repository   Repository   @relation(fields: [repositoryId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
}

model PricingPlan {
  id              String               @id @default(uuid())
  name            String
  planType        SubscriptionPlanType
  basePrice       Float // Base price per project
  evaluationPrice Float // Price per evaluation
  prAnalysisQuota Int                  @default(20)
  assistantQuota  Int                  @default(50)
  active          Boolean              @default(true)
  stripeProductId String? // Stripe product ID
  stripePriceId   String? // Stripe price ID
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id                   String       @id @default(uuid())
  organizationId       String
  organization         Organization @relation(fields: [organizationId], references: [id])
  pricingPlanId        String
  pricingPlan          PricingPlan  @relation(fields: [pricingPlanId], references: [id])
  stripeCustomerId     String? // Keep as is, don't change to a relation yet
  stripeSubscriptionId String? // Stripe subscription ID
  startDate            DateTime     @default(now())
  endDate              DateTime?
  isActive             Boolean      @default(true)
  customBasePrice      Float? // Only for custom plans
  customEvalPrice      Float? // Only for custom plans
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  invoices  Invoice[]
  usageLogs UsageLog[]
}

model Invoice {
  id                    String        @id @default(uuid())
  subscriptionId        String
  subscription          Subscription  @relation(fields: [subscriptionId], references: [id])
  invoiceNumber         String        @unique
  amount                Float
  tax                   Float         @default(0)
  discountAmount        Float         @default(0) // Added discount amount
  total                 Float
  status                InvoiceStatus @default(DRAFT)
  dueDate               DateTime
  paidDate              DateTime?
  stripeInvoiceId       String? // Stripe invoice ID
  stripePaymentIntentId String? // Stripe payment intent ID
  description           String?
  appliedDiscountId     String? // Reference to applied discount
  appliedDiscount       Discount?     @relation(fields: [appliedDiscountId], references: [id])
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  invoiceItems InvoiceItem[]
}

model Discount {
  id             String         @id @default(uuid())
  name           String // e.g., "Task Completion Bonus", "New User Discount"
  description    String? // Optional description
  type           DiscountType // PERCENTAGE or FIXED
  value          Float // Percentage (0-100) or fixed amount in dollars
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  status         DiscountStatus @default(ACTIVE)
  durationMonths Int            @default(1) // How many months the discount is valid
  claimedAt      DateTime? // When the discount was claimed
  expiresAt      DateTime? // When the discount expires
  isAutoApplied  Boolean        @default(false) // Whether to auto-apply on invoices
  maxUsageCount  Int            @default(1) // How many times it can be used
  usedCount      Int            @default(0) // How many times it has been used
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Relations
  appliedInvoices Invoice[] // Invoices where this discount was applied
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id])
  description String
  quantity    Int
  unitPrice   Float
  amount      Float
  type        String // PROJECT or EVALUATION
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UsageLog {
  id             String       @id @default(uuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  repositoryId   String?
  repository     Repository?  @relation(fields: [repositoryId], references: [id])
  type           String // PR_ANALYSIS, ASSISTANT_QUESTION, etc.
  description    String
  counted        Boolean      @default(false) // Whether it's been counted in an invoice
  invoiceId      String? // The invoice it was counted in
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

