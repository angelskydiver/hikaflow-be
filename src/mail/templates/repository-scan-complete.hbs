<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Repository Scan Complete</title>
    <style>
      body { font-family: 'Segoe UI', Arial, sans-serif; margin: 0; padding: 0;
      background-color: #111B21; color: #e0e0e0; } .container { max-width:
      600px; margin: 20px auto; background: #202C33; border-radius: 12px;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2); overflow: hidden; } .banner {
      background: #222E35; padding: 24px; text-align: left; } .logo { font-size:
      32px; font-weight: bold; color: #00A884; margin: 0; letter-spacing: 1px; }
      .wrapper { padding: 32px; } h1 { color: #00A884; margin-bottom: 24px;
      font-size: 24px; } p { color: #e0e0e0; line-height: 1.6; margin-bottom:
      16px; } .button { display: inline-block; padding: 12px 24px; font-size:
      16px; color: #fff; background: linear-gradient(135deg, #00A884, #008c6e);
      text-decoration: none; border-radius: 25px; margin-top: 24px; transition:
      all 0.3s ease; } .button:hover { transform: translateY(-2px); box-shadow:
      0 5px 15px rgba(0, 168, 132, 0.3); } .footer { margin-top: 32px;
      padding-top: 16px; border-top: 1px solid #333; text-align: left;
      font-size: 12px; color: #7C8B95; }
    </style>
  </head>
  <body>
    <div class='container'>
      <div class='banner'>
        <h1 class='logo'>Hikaflow</h1>
      </div>
      <div class='wrapper'>
        <h1>Repository Scan Complete</h1>
        <p>Hi {{adminName}},</p>
        <p>The scan of repository
          <strong>{{repositoryName}}</strong>
          has been completed.</p>
        <a href='{{reportUrl}}' class='button'>View Repository</a>
        <div class='footer'>
          <p>This is an automated message. Please do not reply to this email.</p>
        </div>
      </div>
    </div>
  </body>
</html>