<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Repository Scan Complete</title>
    <style>
      body { font-family: 'Segoe UI', Arial, sans-serif; margin: 0; padding: 0;
      background-color: #111B21; color: #e0e0e0; } .container { max-width:
      600px; margin: 20px auto; background: #202C33; border-radius: 12px;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2); overflow: hidden; } .banner {
      background: #222E35; padding: 24px; text-align: left; } .logo { font-size:
      32px; font-weight: bold; color: #00A884; margin: 0; letter-spacing: 1px; }
      .wrapper { padding: 32px; } h1 { color: #00A884; margin-bottom: 24px;
      font-size: 24px; } h2 { color: #00A884; margin-bottom: 16px; font-size:
      20px; } p { color: #e0e0e0; line-height: 1.6; margin-bottom: 16px; }
      .stats-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap:
      16px; margin: 24px 0; } .stat-item { background: #222E35; padding: 20px;
      border-radius: 10px; text-align: center; border: 1px solid #333; }
      .stat-value { font-size: 28px; font-weight: bold; color: #00A884;
      margin-bottom: 8px; } .stat-label { font-size: 14px; color: #7C8B95; }
      .issues-list { background: #222E35; padding: 24px; border-radius: 10px;
      margin: 24px 0; border: 1px solid #333; } .issue-item { background:
      rgba(34, 46, 53, 0.5); padding: 16px; border-radius: 8px; margin-bottom:
      12px; border: 1px solid #333; } .issue-severity { display: inline-block;
      padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 500;
      margin-right: 8px; } .severity-high { background-color: #ff4444; color:
      #fff; } .severity-medium { background-color: #ffbb33; color: #000; }
      .severity-low { background-color: #00A884; color: #fff; }
      .issue-description { margin-top: 8px; color: #7C8B95; } .button { display:
      inline-block; padding: 12px 24px; font-size: 16px; color: #fff;
      background: linear-gradient(135deg, #00A884, #008c6e); text-decoration:
      none; border-radius: 25px; margin-top: 24px; transition: all 0.3s ease; }
      .button:hover { transform: translateY(-2px); box-shadow: 0 5px 15px
      rgba(0, 168, 132, 0.3); } .footer { margin-top: 32px; padding-top: 16px;
      border-top: 1px solid #333; text-align: left; font-size: 12px; color:
      #7C8B95; }
    </style>
  </head>
  <body>
    <div class='container'>
      <div class='banner'>
        <h1 class='logo'>Hikaflow</h1>
      </div>
      <div class='wrapper'>
        <h1>Repository Scan Complete</h1>
        <p>Hi {{adminName}},</p>
        <p>The scan of repository
          <strong>{{repositoryName}}</strong>
          has been completed. Here's a summary of the findings:</p>

        <div class='stats-grid'>
          <div class='stat-item'>
            <div class='stat-value'>{{totalFiles}}</div>
            <div class='stat-label'>Total Files Scanned</div>
          </div>
          <div class='stat-item'>
            <div class='stat-value'>{{issuesFound}}</div>
            <div class='stat-label'>Issues Found</div>
          </div>
          <div class='stat-item'>
            <div class='stat-value'>{{securityIssues}}</div>
            <div class='stat-label'>Security Issues</div>
          </div>
          <div class='stat-item'>
            <div class='stat-value'>{{codeSmells}}</div>
            <div class='stat-label'>Code Smells</div>
          </div>
        </div>

        {{#if topSecurityIssues.length}}
          <div class='issues-list'>
            <h2>Top Security Issues</h2>
            {{#each topSecurityIssues}}
              <div class='issue-item'>
                <span
                  class='issue-severity severity-{{this.severity}}'
                >{{this.severity}}</span>
                <strong>{{this.title}}</strong>
                <div class='issue-description'>{{this.description}}</div>
              </div>
            {{/each}}
          </div>
        {{/if}}

        {{#if topCodeIssues.length}}
          <div class='issues-list'>
            <h2>Top Code Quality Issues</h2>
            {{#each topCodeIssues}}
              <div class='issue-item'>
                <span
                  class='issue-severity severity-{{this.severity}}'
                >{{this.severity}}</span>
                <strong>{{this.title}}</strong>
                <div class='issue-description'>{{this.description}}</div>
              </div>
            {{/each}}
          </div>
        {{/if}}

        <a href='{{reportUrl}}' class='button'>View Detailed Report</a>

        <div class='footer'>
          <p>This is an automated message. Please do not reply to this email. If
            you have any questions, please contact our support team.</p>
        </div>
      </div>
    </div>
  </body>
</html>