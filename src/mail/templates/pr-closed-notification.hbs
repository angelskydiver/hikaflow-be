<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Pull Request Closed</title>
    <style>
      body { font-family: 'Segoe UI', Arial, sans-serif; margin: 0; padding: 0;
      background-color: #1a1a1a; color: #e0e0e0; -webkit-font-smoothing:
      antialiased; } .container { max-width: 800px; margin: 40px auto;
      background: linear-gradient(145deg, #1e1e1e, #2d2d2d); border-radius:
      16px; box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2); overflow: hidden; }
      .banner { background: linear-gradient(135deg, #2b2b2b, #1a1a1a); padding:
      32px 48px; text-align: left; border-bottom: 1px solid #333; } .logo {
      font-size: 36px; font-weight: bold; color: #4CAF50; margin: 0;
      letter-spacing: 1px; } .wrapper { padding: 48px; } h1 { color: #4CAF50;
      margin: 0 0 32px; font-size: 28px; font-weight: 600; letter-spacing:
      0.5px; } h2 { color: #4CAF50; margin: 0 0 24px; font-size: 22px;
      font-weight: 500; } p { color: #e0e0e0; line-height: 1.8; margin: 0 0
      24px; font-size: 16px; } .stats-grid { display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 24px;
      margin: 32px 0; } .stat-item { background: linear-gradient(145deg,
      #2b2b2b, #232323); padding: 24px; border-radius: 12px; text-align: center;
      border: 1px solid #333; transition: transform 0.2s ease; }
      .stat-item:hover { transform: translateY(-2px); } .stat-value { font-size:
      32px; font-weight: bold; color: #4CAF50; margin-bottom: 12px; }
      .stat-label { font-size: 15px; color: #b0b0b0; letter-spacing: 0.5px; }
      .quality-table { width: 100%; border-collapse: separate; border-spacing:
      0; margin: 32px 0; border-radius: 12px; overflow: hidden; } .quality-table
      th { background: linear-gradient(145deg, #2b2b2b, #232323); color:
      #4CAF50; padding: 20px; text-align: left; font-weight: 500; border-bottom:
      1px solid #333; font-size: 15px; letter-spacing: 0.5px; } .quality-table
      td { background: rgba(43, 43, 43, 0.5); padding: 16px 20px; color:
      #e0e0e0; border-bottom: 1px solid #333; } .quality-table tr:last-child td
      { border-bottom: none; } .improvements-list { background:
      linear-gradient(145deg, #2b2b2b, #232323); padding: 32px; border-radius:
      12px; margin: 32px 0; border: 1px solid #333; } .improvement-item {
      background: rgba(43, 43, 43, 0.5); padding: 24px; border-radius: 12px;
      margin-bottom: 16px; border: 1px solid #333; transition: transform 0.2s
      ease; } .improvement-item:hover { transform: translateY(-2px); }
      .improvement-item:last-child { margin-bottom: 0; } .improvement-title {
      color: #4CAF50; font-weight: 600; margin-bottom: 12px; font-size: 17px; }
      .improvement-description { color: #b0b0b0; line-height: 1.6; font-size:
      15px; } .button { display: inline-block; padding: 16px 32px; font-size:
      16px; color: #fff; background: linear-gradient(135deg, #4CAF50, #45a049);
      text-decoration: none; border-radius: 30px; margin-top: 32px; transition:
      all 0.3s ease; text-align: center; font-weight: 500; letter-spacing:
      0.5px; } .button:hover { transform: translateY(-2px); box-shadow: 0 8px
      20px rgba(76, 175, 80, 0.3); } .footer { margin-top: 48px; padding-top:
      24px; border-top: 1px solid #333; text-align: left; font-size: 14px;
      color: #888; line-height: 1.6; } @media (max-width: 768px) { .container {
      margin: 20px; width: auto; } .wrapper { padding: 24px; } .banner {
      padding: 24px; } .stats-grid { grid-template-columns: 1fr; }
      .quality-table { display: block; overflow-x: auto;
      -webkit-overflow-scrolling: touch; } }
    </style>
  </head>
  <body>
    <div class='container'>
      <div class='banner'>
        <h1 class='logo'>Hikaflow</h1>
      </div>
      <div class='wrapper'>
        <h1>Pull Request Closed</h1>
        <p>Hi {{adminName}},</p>
        <p>
          The pull request in
          <strong>{{repositoryName}}</strong>
          by
          <strong>{{authorName}}</strong>
          has been closed. Here's a summary of the changes:
        </p>

        <div class='stats-grid'>
          <div class='stat-item'>
            <div class='stat-value'>{{totalChanges}}</div>
            <div class='stat-label'>Total Changes</div>
          </div>
          <div class='stat-item'>
            <div class='stat-value'>{{resolvedIssues}}</div>
            <div class='stat-label'>Resolved Issues</div>
          </div>
          <div class='stat-item'>
            <div class='stat-value'>{{reviewComments}}</div>
            <div class='stat-label'>Review Comments</div>
          </div>
          <div class='stat-item'>
            <div class='stat-value'>{{timeToMerge}}</div>
            <div class='stat-label'>Time to Merge</div>
          </div>
        </div>

        <div class='improvements-list'>
          <h2>Final Code Quality Analysis</h2>
          <table class='quality-table'>
            <thead>
              <tr>
                <th>Metric</th>
                <th>Before</th>
                <th>After</th>
                <th>Improvement</th>
              </tr>
            </thead>
            <tbody>
              {{#each qualityMetrics}}
                <tr>
                  <td>{{this.metric}}</td>
                  <td>{{this.before}}</td>
                  <td>{{this.after}}</td>
                  <td>{{this.improvement}}</td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>

        <div class='improvements-list'>
          <h2>Key Improvements</h2>
          {{#each improvements}}
            <div class='improvement-item'>
              <div class='improvement-title'>{{this.title}}</div>
              <div class='improvement-description'>{{this.description}}</div>
            </div>
          {{/each}}
        </div>

        <a href='{{reportUrl}}' class='button'>View Detailed Report</a>

        <div class='footer'>
          <p>
            This is an automated message. Please do not reply to this email. If
            you have any questions, please contact our support team.
          </p>
        </div>
      </div>
    </div>
  </body>
</html>