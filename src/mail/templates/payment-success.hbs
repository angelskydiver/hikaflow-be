<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Payment Successful</title>
    <style>
      body { font-family: 'Nunito Sans', 'Segoe UI', Arial, sans-serif; margin:
      0; padding: 0; background-color: #121212; color: #b3b3b3; } .container {
      max-width: 600px; margin: 20px auto; background: #282828; border-radius:
      16px; box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3); overflow: hidden; }
      .banner { background: linear-gradient(135deg, #4fc372, #6cd591); padding:
      32px; text-align: left; } .logo { font-size: 32px; font-weight: bold;
      color: #ffffff; margin: 0; letter-spacing: 1px; } .wrapper { padding:
      40px; } h1 { color: #4fc372; margin-bottom: 24px; font-size: 28px;
      font-weight: 600; } p { color: #b3b3b3; line-height: 1.6; margin-bottom:
      16px; font-size: 16px; } .payment-info { background: #181818; padding:
      32px; border-radius: 12px; margin: 32px 0; border: 1px solid #535353; }
      .payment-meta { display: grid; grid-template-columns: repeat(2, 1fr); gap:
      20px; margin-bottom: 16px; } .meta-item { background: #282828; padding:
      20px; border-radius: 10px; border: 1px solid #535353; transition: all 0.3s
      ease; } .meta-item:hover { transform: translateY(-2px); box-shadow: 0 4px
      12px rgba(79, 195, 114, 0.1); } .meta-label { font-size: 14px; color:
      #7c8b95; margin-bottom: 8px; font-weight: 500; } .meta-value { font-size:
      16px; font-weight: 600; color: #b3b3b3; word-break: break-word; }
      .success-message { background: rgba(79, 195, 114, 0.1); border: 1px solid
      #4fc372; border-radius: 10px; padding: 20px; margin: 20px 0; text-align:
      center; } .success-icon { font-size: 48px; margin-bottom: 16px; } .button
      { display: inline-block; padding: 14px 32px; font-size: 16px; color:
      #ffffff; background: linear-gradient(135deg, #4fc372, #6cd591);
      text-decoration: none; border-radius: 30px; margin-top: 24px; transition:
      all 0.3s ease; font-weight: 500; text-align: center; } .button:hover {
      transform: translateY(-2px); box-shadow: 0 6px 20px rgba(79, 195, 114,
      0.3); background: linear-gradient(135deg, #6cd591, #4fc372); } .footer {
      margin-top: 40px; padding-top: 20px; border-top: 1px solid #535353;
      text-align: left; font-size: 13px; color: #7c8b95; } .status-badge {
      display: inline-block; padding: 6px 12px; background: rgba(79, 195, 114,
      0.2); color: #4fc372; border-radius: 20px; font-size: 12px; font-weight:
      600; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom:
      16px; } /* Responsive design for mobile devices */ @media (max-width:
      600px) { .container { margin: 10px; border-radius: 12px; } .wrapper {
      padding: 24px; } .payment-info { padding: 20px; } .payment-meta {
      grid-template-columns: 1fr; gap: 16px; } h1 { font-size: 24px; } .logo {
      font-size: 28px; } .banner { padding: 24px; } } /* Responsive design for
      very small screens */ @media (max-width: 480px) { .wrapper { padding:
      16px; } .payment-info { padding: 16px; } .success-message { padding: 16px;
      } }
    </style>
  </head>
  <body>
    <div class='container'>
      <div class='banner'>
        <h1 class='logo'>Codedeno</h1>
      </div>
      <div class='wrapper'>
        <div class='status-badge'>✅ Success</div>
        <h1>Payment Successful</h1>
        <p>Hi <strong>{{userName}}</strong>,</p>
        <p>
          Your payment has been processed successfully. Thank you for your
          purchase!
        </p>

        <div class='success-message'>
          <div class='success-icon'>🎉</div>
          <h3 style='color: #4fc372; margin: 0 0 8px 0; font-size: 20px;'>
            Payment Confirmed
          </h3>
          <p style='margin: 0; color: #b3b3b3;'>
            Your transaction has been completed successfully
          </p>
        </div>

        <div class='payment-info'>
          <div class='payment-meta'>
            <div class='meta-item'>
              <div class='meta-label'>Invoice Number</div>
              <div class='meta-value'>{{transactionId}}</div>
            </div>
            <div class='meta-item'>
              <div class='meta-label'>Amount</div>
              <div class='meta-value'>${{amount}}</div>
            </div>
            <div class='meta-item'>
              <div class='meta-label'>Payment Method</div>
              <div class='meta-value'>{{paymentMethod}}</div>
            </div>
            <div class='meta-item'>
              <div class='meta-label'>Date</div>
              <div class='meta-value'>{{paymentDate}}</div>
            </div>
          </div>

          {{#if planDetails}}
            <div
              style='margin-top: 20px; padding-top: 20px; border-top: 1px solid #535353;'
            >
              <h4 style='color: #4fc372; margin-bottom: 12px; font-size: 16px;'>
                📦 Plan Details
              </h4>
              <div
                style='background: #222e35; padding: 16px; border-radius: 8px; border-left: 4px solid #4fc372;'
              >
                <div
                  style='font-weight: 600; color: #b3b3b3; margin-bottom: 4px;'
                >
                  {{planDetails.name}}
                </div>
                <div style='font-size: 14px; color: #7c8b95;'>
                  {{planDetails.description}}
                </div>
              </div>
            </div>
          {{/if}}
        </div>

        <a href='{{dashboardUrl}}' class='button'>Go to Dashboard</a>

        <div class='footer'>
          <p>
            This is an automated message from Hikaflow. Please do not reply to
            this email.
          </p>
          <p>
            If you have any questions about this payment, please contact our
            support team.
          </p>
        </div>
      </div>
    </div>
  </body>
</html>